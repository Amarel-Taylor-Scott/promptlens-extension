{
  "manifest_version": 3,
  "name": "PromptLens — AI Image Prompt Extractor",
  "description": "Right-click any AI-generated image to instantly extract its generation prompt",
  "version": "1.0.0",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://promptlens.polsia.app/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "PromptLens"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
