{
  "manifest_version": 2,
  "name": "PromptLens — AI Image Prompt Extractor",
  "description": "Right-click any AI-generated image to instantly extract its generation prompt",
  "version": "1.0.0",
  "permissions": [
    "contextMenus",
    "storage",
    "notifications",
    "activeTab",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "promptlens@polsia.app",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["websiteContent"],
        "optional": ["personallyIdentifyingInfo"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "PromptLens"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true,
    "browser_style": false
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
